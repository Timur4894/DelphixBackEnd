						"url": {
							"raw": "{{base_url}}/portfolio-companies/ticker/:ticker",
							"host": ["{{base_url}}"],
							"path": ["portfolio-companies", "ticker", ":ticker"],
							"variable": [{"key": "ticker", "value": "AAPL"}]
						},
						"description": "Получить компанию из портфеля по тикеру (например, AAPL, MSFT) с расчетом прибыли/убытка на основе актуальной цены из Alpha Vantage API.\n\nВозвращает те же поля, что и Get My Portfolio, но для одной компании."
					}
				},
				{
					"name": "Get Company Transactions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/portfolio-companies/ticker/:ticker/transactions",
							"host": ["{{base_url}}"],
							"path": ["portfolio-companies", "ticker", ":ticker", "transactions"],
							"variable": [{"key": "ticker", "value": "AAPL"}]
						},
						"description": "Получить все транзакции по конкретной компании из портфеля.\n\nИспользуется для экрана деталей компании - показывает все покупки/продажи этой компании.\n\nВозвращает:\n- portfolio_company: информация о компании в портфеле\n- transactions: список всех транзакций (BUY/SELL)"
					}
				}
			]
